---
import Layout from '@/layouts/Layout.astro'
import { porra } from '@/consts/pageTitles'
import { COMBATS } from '@/consts/combats'
import { getBoxerById } from '@/lib/boxers'
import { getAllPredictions, getUserVotes, type CombatPrediction } from '@/lib/predictions'
import PredictionBar from '@/components/PredictionBar.astro'
import SectionTitle from '@/components/SectionTitle.astro'
import VersusIcon from '@/components/VersusIcon.astro'
import { extractUserId } from '@/lib/auth'

const description =
  'Participa en la porra oficial de La Velada del Año VI y haz tus predicciones sobre los combates de Ibai Llanos y creadores de contenido.'
const canonical = 'https://www.infolavelada.com/porra'

// Obtener predicciones actuales
let predictions: Record<string, { fighter_id: string; votes: number; percentage: number }[]> = {}
try {
  const allPredictions = await getAllPredictions()
  predictions = Object.fromEntries(
    allPredictions.map((p) => [p.combat_id, p.predictions])
  )
} catch {
  // Use defaults
}

// Obtener ID de usuario (anónimo o sesión)
const userId = extractUserId(Astro.request)

// Obtener votos previos del usuario
let userVotes: Record<string, string> = {}
try {
  const votes = await getUserVotes(userId)
  userVotes = Object.fromEntries(votes.map((v) => [v.combat_id, v.fighter_id]))
} catch (error) {
  console.error('Error fetching user votes:', error)
}

export const prerender = false
---

<Layout title={porra} description={description} canonical={canonical}>
  <section class="mx-auto mt-24 flex min-h-screen w-full flex-col items-center justify-start gap-6 px-4 pb-24">

    <!-- Header de sección -->
    <div class="mt-2 flex flex-col items-center gap-3">
      <SectionTitle title="LA PORRA" />
      <p class="max-w-xl text-center text-sm lowercase text-white/60 tracking-wide">
        Elige quién crees que ganará cada combate de La Velada del Año VI
      </p>
    </div>

    <!-- Grid de combates -->
    <div
      id="combats-container"
      class="relative mx-auto mt-6 grid w-full max-w-7xl grid-cols-1 gap-6 lg:grid-cols-2"
    >
      {
        COMBATS.toReversed().map(({ id, number, fighters, title }, index) => {
          const fighter1 = getBoxerById(fighters[0])
          const fighter2 = getBoxerById(fighters[1])
          const combatPredictions = predictions[id] || [
            { fighter_id: fighters[0], votes: 0, percentage: 50 },
            { fighter_id: fighters[1], votes: 0, percentage: 50 },
          ]
          const p1 = combatPredictions.find(p => p.fighter_id === fighters[0]) || { percentage: 50, votes: 0 }
          const p2 = combatPredictions.find(p => p.fighter_id === fighters[1]) || { percentage: 50, votes: 0 }
          const totalVotes = (p1.votes || 0) + (p2.votes || 0)

          return (
            <article
              data-combat-id={id}
              data-user-vote={userVotes[id]}
              data-voted={userVotes[id] ? 'true' : undefined}
              class:list={[
                'group relative overflow-hidden rounded-2xl border border-white/10 bg-theme-midnight/40 transition-all duration-500 hover:border-theme-gold/30 hover:shadow-[0_0_50px_rgba(199,168,107,0.1)]',
                index === 0 ? 'lg:col-span-2' : '',
              ]}
            >
              <!-- Badge combate número -->
              <div class="absolute left-2 top-2 z-30">
                <span class="rounded-full bg-black/40 px-3 py-1 font-cinzel text-[10px] font-bold uppercase tracking-widest text-theme-gold backdrop-blur-md border border-theme-gold/20">
                  COMBATE #{number}
                </span>
              </div>

              <!-- Fighters row -->
              <div
                class:list={[
                  'relative flex w-full overflow-hidden',
                  index === 0 ? 'h-64 sm:h-80 md:h-[450px]' : 'h-48 sm:h-64 md:h-80',
                ]}
              >
                {/* Fighter 1 */}
                <button
                  type="button"
                  class="vote-btn group/btn relative flex h-full w-1/2 cursor-pointer items-end justify-center overflow-hidden border-0 bg-transparent p-0 transition-all duration-500 hover:z-20"
                  data-combat-id={id}
                  data-fighter-id={fighters[0]}
                  data-is-user-vote={userVotes[id] === fighters[0] ? 'true' : undefined}
                  aria-label={`Votar por ${fighter1?.name}`}
                >
                  <img
                    src={`/images/fighters/cards/${fighters[0]}.webp`}
                    class="h-full w-full object-cover object-top transition-all duration-700 group-hover/btn:scale-110 group-hover/btn:brightness-110"
                    alt={`Imagen de ${fighter1?.name}`}
                    transition:name={`combat-img:${fighters[0]}`}
                    loading={index === 0 ? 'eager' : 'lazy'}
                    decoding="async"
                  />
                  
                  <!-- Overlay Gradiente -->
                  <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent transition-opacity duration-500 group-hover/btn:from-pink-900/40"></div>

                  <!-- Overlay de voto -->
                  <div class="pointer-events-none absolute inset-0 flex flex-col items-center justify-center bg-pink-500/0 transition-all duration-300 group-hover/btn:bg-pink-500/10">
                    <span class="translate-y-4 transform rounded-full border border-theme-gold/30 bg-black/60 px-6 py-2 font-cinzel text-xs font-bold tracking-widest text-theme-gold opacity-0 backdrop-blur-md transition-all duration-300 group-hover/btn:translate-y-0 group-hover/btn:opacity-100">
                      VOTAR
                    </span>
                  </div>

                  <!-- Nombre fighter -->
                  <div class="absolute bottom-6 left-0 right-0 z-20 px-4 text-center">
                    <span class="block font-cinzel text-xs font-bold tracking-widest text-white drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)] sm:text-sm md:text-base">{fighter1?.name}</span>
                  </div>
                </button>

                {/* VS Element */}
                <div class="pointer-events-none absolute inset-0 z-30 flex items-center justify-center">
                  <div class="relative flex items-center justify-center">
                    <div class="absolute h-16 w-16 animate-pulse rounded-full bg-theme-gold/10 blur-xl"></div>
                    <div class="relative flex h-10 w-10 items-center justify-center rounded-full border border-theme-gold/20 bg-black/60 shadow-[0_0_20px_rgba(199,168,107,0.2)] backdrop-blur-md md:h-14 md:w-14">
                      <VersusIcon class="h-6 w-6 text-theme-gold md:h-8 md:w-8" />
                    </div>
                  </div>
                </div>

                {/* Fighter 2 */}
                <button
                  type="button"
                  class="vote-btn group/btn relative flex h-full w-1/2 cursor-pointer items-end justify-center overflow-hidden border-0 bg-transparent p-0 transition-all duration-500 hover:z-20"
                  data-combat-id={id}
                  data-fighter-id={fighters[1]}
                  data-is-user-vote={userVotes[id] === fighters[1] ? 'true' : undefined}
                  aria-label={`Votar por ${fighter2?.name}`}
                >
                  <img
                    src={`/images/fighters/cards/${fighters[1]}.webp`}
                    class="h-full w-full object-cover object-top transition-all duration-700 group-hover/btn:scale-110 group-hover/btn:brightness-110"
                    alt={`Imagen de ${fighter2?.name}`}
                    transition:name={`combat-img:${fighters[1]}`}
                    loading="lazy"
                    decoding="async"
                  />

                  <!-- Overlay Gradiente -->
                  <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent transition-opacity duration-500 group-hover/btn:from-blue-900/40"></div>

                  <!-- Overlay de voto -->
                  <div class="pointer-events-none absolute inset-0 flex flex-col items-center justify-center bg-blue-500/0 transition-all duration-300 group-hover/btn:bg-blue-500/10">
                    <span class="translate-y-4 transform rounded-full border border-theme-gold/30 bg-black/60 px-6 py-2 font-cinzel text-xs font-bold tracking-widest text-theme-gold opacity-0 backdrop-blur-md transition-all duration-300 group-hover/btn:translate-y-0 group-hover/btn:opacity-100">
                      VOTAR
                    </span>
                  </div>

                  <!-- Nombre fighter -->
                  <div class="absolute bottom-6 left-0 right-0 z-20 px-4 text-center">
                    <span class="block font-cinzel text-xs font-bold tracking-widest text-white drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)] sm:text-sm md:text-base">{fighter2?.name}</span>
                  </div>
                </button>

                <!-- Barra de predicciones integrada -->
                <div class="pointer-events-none absolute bottom-0 left-0 right-0 z-40" data-prediction-bar={id}>
                  <PredictionBar
                    variant="minimal"
                    showInitial={true}
                    disableLink={true}
                    combatId={id}
                    overlay={false}
                    fighter1={{
                      id: fighter1?.id || '',
                      name: fighter1?.name || '',
                      percentage: p1.percentage,
                    }}
                    fighter2={{
                      id: fighter2?.id || '',
                      name: fighter2?.name || '',
                      percentage: p2.percentage,
                    }}
                  />
                </div>
              </div>

              <!-- Mensaje de voto confirmado -->
              <div
                class="vote-success pointer-events-none absolute inset-0 z-50 flex items-center justify-center opacity-0 transition-opacity duration-500"
                data-combat-success={id}
              >
                <div class="rounded-2xl border border-green-400/30 bg-black/80 px-8 py-4 text-center shadow-2xl backdrop-blur-md">
                  <span class="font-cinzel text-sm font-bold tracking-widest text-green-400 uppercase">¡Voto registrado!</span>
                </div>
              </div>
            </article>
          )
        })
      }
    </div>
  </section>
</Layout>

<script>
  import confetti from 'canvas-confetti'

  document.addEventListener('astro:page-load', async () => {
    const voteButtons = document.querySelectorAll<HTMLButtonElement>('.vote-btn')

    voteButtons.forEach((btn) => {
      btn.addEventListener('click', async () => {
        const combatId = btn.getAttribute('data-combat-id')
        const fighterId = btn.getAttribute('data-fighter-id')

        if (!combatId || !fighterId) return

        // Evitar doble voto mientras procesa
        const article = btn.closest('article')
        if (!article || article.hasAttribute('data-voted')) return
        article.setAttribute('data-voted', 'true')

        try {
          const response = await fetch('/api/predictions', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ combatId, fighterId }),
          })

          if (response.ok) {
            article.setAttribute('data-voted', 'true')
            btn.setAttribute('data-is-user-vote', 'true')
            const data = await response.json()
            // Confeti
            confetti({
              particleCount: 120,
              spread: 70,
              origin: { y: 0.6 },
              colors: ['#c7a86b', '#ff4f9f', '#00aba5'],
            })

            // Mostrar mensaje de éxito sobre la card
            const successMsg = document.querySelector(`[data-combat-success="${combatId}"]`) as HTMLElement
            if (successMsg) {
              successMsg.classList.remove('opacity-0')
              successMsg.classList.add('opacity-100')
              setTimeout(() => {
                successMsg.classList.remove('opacity-100')
                successMsg.classList.add('opacity-0')
              }, 2000)
            }

            // Actualizar la barra de predicciones con los datos devueltos por la API
            const combatData = data?.predictions
            if (combatData?.predictions) {
              document.dispatchEvent(
                new CustomEvent('update-prediction-bar', {
                  detail: {
                    id: combatId,
                    data: {
                      predictions: combatData.predictions,
                      total_votes: combatData.total_votes ?? 0,
                    },
                  },
                }),
              )
            }
          } else {
            // Si la API rechazó, permitir reintentar
            article.removeAttribute('data-voted')
          }
        } catch (error) {
          console.error('Error registrando el voto:', error)
          article.removeAttribute('data-voted')
        }
      })
    })
  })
</script>

<style>
  /* Card con voto ya emitido: deshabilita hover de botones */
  article[data-voted] .vote-btn {
    cursor: default;
    pointer-events: none;
    filter: grayscale(0.5) brightness(0.7);
  }

  /* El botón que el usuario eligió */
  article[data-voted] .vote-btn[data-is-user-vote="true"] {
    filter: grayscale(0) brightness(1.1);
    z-index: 10;
  }

  article[data-voted] .vote-btn[data-is-user-vote="true"]::after {
    content: '✓ TU ELECCIÓN';
    position: absolute;
    bottom: 3.5rem;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0, 0, 0, 0.85);
    color: #c7a86b;
    padding: 0.5rem 1.25rem;
    border-radius: 9999px;
    font-family: 'Cinzel', serif;
    font-size: 0.65rem;
    font-weight: 900;
    letter-spacing: 0.15em;
    border: 1px solid rgba(199, 168, 107, 0.6);
    backdrop-filter: blur(6px);
    white-space: nowrap;
    z-index: 40;
    box-shadow: 0 0 20px rgba(199, 168, 107, 0.3);
  }
</style>
