---
interface Props {
  disableLink?: boolean
  combatId: string
  fighter1: {
    id: string
    name: string
    percentage: number
  }
  fighter2: {
    id: string
    name: string
    percentage: number
  }
  overlay?: boolean
  totalVotes?: number
  variant?: 'full' | 'minimal'
  showInitial?: boolean
}

const {
  disableLink = false,
  combatId,
  fighter1,
  fighter2,
  overlay = false,
  totalVotes,
  variant = 'full',
  showInitial = false,
} = Astro.props

const isMinimal = variant === 'minimal'
---

<div
  id={`prediction-bar-${combatId}`}
  class:list={[
    overlay
      ? 'absolute left-1/2 -translate-x-1/2 bottom-0 z-30 w-full flex justify-center'
      : 'w-full flex flex-col items-center',
    'pointer-events-none flex-col justify-center items-center transition-opacity duration-700',
    showInitial ? 'opacity-100' : 'opacity-0',
    isMinimal ? 'px-0' : '',
  ]}
>
  <!-- Barra clickeable -->
  <a
    href="/porra"
    class:list={[
      'group pointer-events-auto block w-full transition-transform duration-300 hover:scale-[1.02]',
      disableLink ? 'pointer-events-none' : '',
      isMinimal ? 'max-w-none' : 'max-w-3xl',
    ]}
  >
    <div
      class:list={[
        'relative flex w-full overflow-hidden backdrop-blur-sm transition-all duration-500',
        isMinimal 
          ? 'h-4 border-y border-white/10 bg-black/20 group-hover:h-5 group-hover:border-white/20' 
          : 'h-12 rounded-full border-2 border-white/20 bg-black/40 shadow-[0_0_20px_rgba(0,0,0,0.5)] md:h-14',
      ]}
    >
      <!-- Barra del primer combatiente -->
      <div
        data-fighter-id={fighter1.id}
        class="prediction-bar-fighter-1 relative flex h-full flex-col items-center justify-center overflow-hidden transition-all duration-1000 ease-out"
        style={`width: ${fighter1.percentage}%`}
      >
        <div class:list={[
          'absolute inset-0 bg-gradient-to-r from-pink-600 via-pink-500 to-pink-400',
          isMinimal ? 'opacity-80 group-hover:opacity-100 shadow-[0_0_15px_rgba(219,39,119,0.5)]' : ''
        ]}></div>
        <div class="shine-effect absolute inset-0 w-full animate-shine bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>
        
        {isMinimal && (
          <span class="prediction-bar-percentage relative z-10 px-2 font-cinzel text-[10px] font-black leading-none text-white drop-shadow-md md:text-xs">
            {fighter1.percentage}%
          </span>
        )}

        {!isMinimal && (
          <div class="relative z-10 flex flex-col items-center justify-center">
            <span class="text-[10px] font-bold uppercase leading-none tracking-widest drop-shadow-md sm:text-xs md:text-sm">
              {fighter1.name}
            </span>
            <span class="prediction-bar-percentage mt-0.5 text-xs font-black leading-none drop-shadow-md md:text-base">
              {fighter1.percentage}%
            </span>
          </div>
        )}
      </div>

      <!-- Barra del segundo combatiente -->
      <div
        data-fighter-id={fighter2.id}
        class="prediction-bar-fighter-2 relative flex h-full flex-col items-center justify-center overflow-hidden transition-all duration-1000 ease-out"
        style={`width: ${fighter2.percentage}%`}
      >
        <div class:list={[
          'absolute inset-0 bg-gradient-to-l from-sky-600 via-sky-500 to-blue-500',
          isMinimal ? 'opacity-80 group-hover:opacity-100 shadow-[0_0_15px_rgba(14,165,233,0.5)]' : ''
        ]}></div>
        <div class="shine-effect absolute inset-0 w-full animate-shine bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>

        {isMinimal && (
          <span class="prediction-bar-percentage relative z-10 px-2 font-cinzel text-[10px] font-black leading-none text-white drop-shadow-md md:text-xs">
            {fighter2.percentage}%
          </span>
        )}

        {!isMinimal && (
          <div class="relative z-10 flex flex-col items-center justify-center">
            <span class="text-[10px] font-bold uppercase leading-none tracking-widest drop-shadow-md sm:text-xs md:text-sm">
              {fighter2.name}
            </span>
            <span class="prediction-bar-percentage mt-0.5 text-xs font-black leading-none drop-shadow-md md:text-base">
              {fighter2.percentage}%
            </span>
          </div>
        )}
      </div>
    </div>
  </a>

  <!-- Texto con el número de votaciones (fuera del área clickeable) -->
  {
    totalVotes && !isMinimal && (
      <p class="animate-delay-300 mt-3 rounded-full bg-black/50 px-4 py-1 text-center text-xs lowercase text-white/70 opacity-0 backdrop-blur-sm">
        Basado en{' '}
        <span class="prediction-bar-votes font-semibold text-white">
          {totalVotes.toLocaleString()}
        </span>{' '}
        votaciones de usuarios
      </p>
    )
  }
</div>

<script>
  // listen an event to update the prediction bar
  document.addEventListener('update-prediction-bar', (event) => {
    const {
      id,
      data: { predictions, total_votes: totalVotes },
    } = (event as CustomEvent).detail
    const predictionBar = document.getElementById(`prediction-bar-${id}`)

    if (predictionBar) {
      const $votes = predictionBar.querySelector('.prediction-bar-votes')
      const $votesParent = $votes?.parentNode as HTMLElement

      if ($votes && $votesParent) {
        $votes.textContent = totalVotes.toLocaleString()
        $votesParent.classList.add('opacity-0')
        $votesParent.classList.add('animate-fade-in')
      }

      predictions.map((prediction: { fighter_id: string; percentage: number; votes: number }) => {
        const $fighter = predictionBar.querySelector(
          `[data-fighter-id="${prediction.fighter_id}"]`,
        ) as HTMLElement

        if ($fighter) {
          $fighter.style.width = `${prediction.percentage}%`
          const $percentage = $fighter.querySelector('.prediction-bar-percentage') as HTMLElement

          if ($percentage) {
            $percentage.textContent = `${prediction.percentage}%`
          }
        }
      })

      predictionBar.classList.remove('opacity-0')
      predictionBar.classList.add('animate-fade-in')
    }
  })
</script>

<style>
  @keyframes shine {
    0% {
      transform: translateX(-100%);
    }
    100% {
      transform: translateX(100%);
    }
  }

  .animate-shine {
    animation: shine 3s infinite ease-in-out;
  }

  .prediction-bar-fighter-1, .prediction-bar-fighter-2 {
    transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);
  }
</style>
