---
// Using plain <img> because provided image paths are runtime strings from constants,
// which aren't compatible with astro:assets <Image /> metadata requirements.

interface Props {
  name: string
  image: string
}

const { name, image } = Astro.props
---

<article
  class="group relative overflow-hidden rounded-2xl border border-white/10 bg-gradient-to-br from-pink-950/40 to-theme-midnight/80 shadow-lg transition-all duration-500 hover:border-theme-gold/40 hover:shadow-[0_0_30px_rgba(199,168,107,0.12)]"
>
  <!-- Image -->
  <div class="relative overflow-hidden">
    <img
      src={image}
      alt={name}
      class="aspect-[4/3] w-full object-cover transition-transform duration-700 group-hover:scale-105"
      loading="lazy"
      decoding="async"
      width="400"
      height="300"
      onerror="this.style.opacity='0.3'"
    />
    <!-- Gradient overlay -->
    <div
      class="absolute inset-0 bg-gradient-to-t from-theme-midnight/90 via-transparent to-transparent"
    >
    </div>
  </div>

  <!-- Name -->
  <div class="px-5 py-4">
    <h2
      class="text-center font-cinzel text-lg font-bold tracking-wide text-white transition-colors duration-300 group-hover:text-theme-gold"
    >
      {name}
    </h2>
    <p class="mt-1 text-center text-xs uppercase tracking-widest text-white/30">
      Artista · La Velada VI
    </p>
  </div>
</article>
