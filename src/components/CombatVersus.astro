---
import PredictionBar from '@/components/PredictionBar.astro'
import VersusIcon from '@/components/VersusIcon.astro'

import { COMBATS } from '@/consts/combats'
import { FIGHTERS } from '@/consts/fighters'

const { id = '' } = Astro.props
const combat = COMBATS.find((c) => c.id === id)

const fighter1 = FIGHTERS.find((f) => f.id === combat?.fighters[0])
const fighter2 = FIGHTERS.find((f) => f.id === combat?.fighters[1])
---

<div
  data-combat-id={id}
  class="relative overflow-hidden rounded-2xl border border-white/10 h-[320px] sm:h-[420px] md:h-[520px]"
>
  <!-- Fighters row -->
  <div class="relative flex h-full w-full">

    <!-- Fighter 1 -->
    <a
      href={`/luchador/${fighter1?.id}`}
      data-astro-prefetch="hover"
      class="group/f1 relative flex h-full w-1/2 overflow-hidden"
    >
      <img
        src={`/images/fighters/cards/${fighter1?.id}.webp`}
        alt={`Imagen de ${fighter1?.name}`}
        class="h-full w-full object-cover object-top transition-all duration-700 group-hover/f1:scale-105 group-hover/f1:brightness-110"
        transition:name={`combat-img:${fighter1?.id}`}
        loading="eager"
        fetchpriority="high"
        decoding="async"
        onerror="this.style.opacity='0'"
      />
      <!-- Overlay gradient desde abajo -->
      <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent"></div>
      <!-- Nombre fighter -->
      <div class="absolute bottom-14 left-0 right-0 z-20 px-4 text-center">
        <span class="block font-cinzel text-xs font-bold tracking-widest text-white drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)] sm:text-sm md:text-base">
          {fighter1?.name}
        </span>
      </div>
    </a>

    <!-- VS Central -->
    <div class="pointer-events-none absolute inset-0 z-30 flex items-center justify-center" transition:name={`vs:${fighter1?.id}-${fighter2?.id}`}>
      <div class="relative flex items-center justify-center">
        <div class="absolute h-16 w-16 animate-pulse rounded-full bg-theme-gold/10 blur-xl"></div>
        <div class="relative flex h-12 w-12 items-center justify-center rounded-full border border-theme-gold/30 bg-black/70 shadow-[0_0_24px_rgba(199,168,107,0.25)] backdrop-blur-md md:h-16 md:w-16">
          <VersusIcon class="h-7 w-7 text-theme-gold md:h-9 md:w-9" />
        </div>
      </div>
    </div>

    <!-- Fighter 2 -->
    <a
      href={`/luchador/${fighter2?.id}`}
      data-astro-prefetch="hover"
      class="group/f2 relative flex h-full w-1/2 overflow-hidden"
    >
      <img
        src={`/images/fighters/cards/${fighter2?.id}.webp`}
        alt={`Imagen de ${fighter2?.name}`}
        class="h-full w-full object-cover object-top transition-all duration-700 group-hover/f2:scale-105 group-hover/f2:brightness-110"
        transition:name={`combat-img:${fighter2?.id}`}
        loading="eager"
        fetchpriority="high"
        decoding="async"
        onerror="this.style.opacity='0'"
      />
      <!-- Overlay gradient desde abajo -->
      <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent"></div>
      <!-- Nombre fighter -->
      <div class="absolute bottom-14 left-0 right-0 z-20 px-4 text-center">
        <span class="block font-cinzel text-xs font-bold tracking-widest text-white drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)] sm:text-sm md:text-base">
          {fighter2?.name}
        </span>
      </div>
    </a>

    <!-- Barra de Predicción al fondo -->
    <div class="pointer-events-none absolute bottom-0 left-0 right-0 z-40">
      <PredictionBar
        combatId={id}
        overlay={false}
        variant="minimal"
        showInitial={true}
        fighter1={{
          id: fighter1?.id || '',
          name: fighter1?.name || '',
          percentage: 60,
        }}
        fighter2={{
          id: fighter2?.id || '',
          name: fighter2?.name || '',
          percentage: 40,
        }}
        totalVotes={100}
      />
    </div>
  </div>
</div>

<script>
  document.addEventListener('astro:page-load', async () => {
    const combatId = document.querySelector('[data-combat-id]')?.getAttribute('data-combat-id')
    if (!combatId) return

    try {
      const response = await fetch(`/api/predictions?combat_id=${combatId}`)
      if (!response.ok) return
      const predictionsData = await response.json()
      const combatPredictions = predictionsData?.predictions

      document.dispatchEvent(
        new CustomEvent('update-prediction-bar', {
          detail: {
            id: combatId,
            data: {
              predictions: combatPredictions?.predictions ?? [],
              total_votes: combatPredictions?.total_votes ?? 0,
            },
          },
        }),
      )
    } catch {
      // Silently fail - bar stays hidden with default values
    }
  })
</script>
