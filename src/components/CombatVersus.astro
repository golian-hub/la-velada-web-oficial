---
import PredictionBar from '@/components/PredictionBar.astro'
import VersusIcon from '@/components/VersusIcon.astro'

import { COMBATS } from '@/consts/combats'
import { FIGHTERS } from '@/consts/fighters'

const { id = '' } = Astro.props
const combat = COMBATS.find((c) => c.id === id)

const fighter1 = FIGHTERS.find((f) => f.id === combat?.fighters[0])
const fighter2 = FIGHTERS.find((f) => f.id === combat?.fighters[1])
---

<div data-combat-id={id} class="relative -mt-10 flex h-[60vh] w-full min-h-[320px] max-h-[680px]">
  <!-- Primer Combatiente -->
  <div class="relative h-full w-1/2 overflow-hidden">
    <a
      class="block h-full w-full"
      href={`/luchador/${fighter1?.id}`}
    >
      <img
        src={`/images/fighters/cards/${fighter1?.id}.webp`}
        alt={`Imagen de ${fighter1?.name}`}
        class="h-full w-full object-cover object-top drop-shadow-2xl transition-transform duration-500 hover:scale-110"
        transition:name={`combat-img:${fighter1?.id}`}
        loading="lazy"
        decoding="async"
        onerror="this.parentElement.parentElement.style.display='none'"
      />
    </a>
    <!-- Difuminado borde superior -->
    <div class="pointer-events-none absolute inset-x-0 top-0 h-24 bg-gradient-to-b from-black to-transparent"></div>
    <!-- Difuminado borde derecho (hacia el centro) -->
    <div class="pointer-events-none absolute inset-y-0 right-0 w-24 bg-gradient-to-l from-black to-transparent"></div>
    <!-- Difuminado borde inferior -->
    <div class="pointer-events-none absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-black to-transparent"></div>
  </div>

  <!-- Versus Banner -->
  <div
    class="pointer-events-none absolute bottom-8 left-1/2 z-10 -translate-x-1/2 sm:bottom-12 lg:bottom-16"
    transition:name={`vs:${fighter1?.id}-${fighter2?.id}`}
  >
    <div class="flex items-center gap-3 px-4 py-2 sm:gap-5 sm:px-6 sm:py-3 md:gap-8 md:px-8" style="background: radial-gradient(ellipse at center, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.2) 60%, transparent 100%);">
      <span class="font-cinzel text-right text-xs font-bold uppercase tracking-widest text-white sm:text-base md:text-xl lg:text-2xl">
        {fighter1?.name}
      </span>
      <VersusIcon class="h-10 w-10 text-theme-gold drop-shadow-[0_0_20px_rgba(212,175,55,0.8)] sm:h-14 sm:w-14 lg:h-20 lg:w-20" />
      <span class="font-cinzel text-left text-xs font-bold uppercase tracking-widest text-white sm:text-base md:text-xl lg:text-2xl">
        {fighter2?.name}
      </span>
    </div>
  </div>

  <!-- Segundo Combatiente -->
  <div class="relative h-full w-1/2 overflow-hidden">
    <a class="block h-full w-full" href={`/luchador/${fighter2?.id}`}>
      <img
        src={`/images/fighters/cards/${fighter2?.id}.webp`}
        alt={`Imagen de ${fighter2?.name}`}
        class="h-full w-full object-cover object-top drop-shadow-2xl transition-transform duration-500 hover:scale-110"
        transition:name={`combat-img:${fighter2?.id}`}
        loading="lazy"
        decoding="async"
        onerror="this.parentElement.parentElement.style.display='none'"
      />
    </a>
    <!-- Difuminado borde superior -->
    <div class="pointer-events-none absolute inset-x-0 top-0 h-24 bg-gradient-to-b from-black to-transparent"></div>
    <!-- Difuminado borde izquierdo (hacia el centro) -->
    <div class="pointer-events-none absolute inset-y-0 left-0 w-24 bg-gradient-to-r from-black to-transparent"></div>
    <!-- Difuminado borde inferior -->
    <div class="pointer-events-none absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-black to-transparent"></div>
  </div>
  <!-- Barra de Predicción Overlay -->
  <PredictionBar
    combatId={id}
    overlay={true}
    variant="minimal"
    fighter1={{
      id: fighter1?.id || '',
      name: fighter1?.name || '',
      percentage: 60,
    }}
    fighter2={{
      id: fighter2?.id || '',
      name: fighter2?.name || '',
      percentage: 40,
    }}
    totalVotes={100}
  />
</div>

<script>
  document.addEventListener('astro:page-load', async () => {
    const combatId = document.querySelector('[data-combat-id]')?.getAttribute('data-combat-id')
    if (!combatId) return

    try {
      const response = await fetch(`/api/predictions?combat_id=${combatId}`)
      if (!response.ok) return
      const predictionsData = await response.json()
      const combatPredictions = predictionsData?.predictions

      document.dispatchEvent(
        new CustomEvent('update-prediction-bar', {
          detail: {
            id: combatId,
            data: {
              predictions: combatPredictions?.predictions ?? [],
              total_votes: combatPredictions?.total_votes ?? 0,
            },
          },
        }),
      )
    } catch {
      // Silently fail - bar stays hidden with default values
    }
  })
</script>
